#===============================================================================
# LDAP 客户端部署 — 变量文件
# 配合 deploy-ldap-client.yml 使用
#
# 密码设置：
#   方式1（推荐）: 直接在 all.yml 中设置 vault_ldap_ro_pw，chmod 600
#   方式2: ansible-vault encrypt_string --name vault_ldap_ro_pw
#   方式3: 运行时传入 --extra-vars "vault_ldap_ro_pw=密码"
#===============================================================================

#------------------------------------------------------------------------------
# LDAP 服务器
#------------------------------------------------------------------------------
ldap_master1: ldap01.example.com
ldap_master2: ldap02.example.com
ldap_suffix: dc=example,dc=com

#------------------------------------------------------------------------------
# 只读账号
#------------------------------------------------------------------------------
ldap_ro_user: readonly
ldap_ro_dn: "cn={{ ldap_ro_user }},{{ ldap_suffix }}"
# ★ 部署前必须设置真实密码（chmod 600 保护此文件）
vault_ldap_ro_pw: CHANGE_ME

#------------------------------------------------------------------------------
# TLS
#------------------------------------------------------------------------------
ldap_tls_cacert: /etc/openldap/certs/ca.crt
ldap_tls_reqcert: demand
ldap_tls_cacert_src: "{{ playbook_dir }}/files/ca.crt"

#------------------------------------------------------------------------------
# URI（ldaps:// 优先 + ldap:// 回退）
#------------------------------------------------------------------------------
ldap_uris: "ldaps://{{ ldap_master1 }}:636 ldaps://{{ ldap_master2 }}:636 ldap://{{ ldap_master1 }}:389 ldap://{{ ldap_master2 }}:389"

# SSSD 用逗号分隔
sssd_ldap_uri: "ldaps://{{ ldap_master1 }}:636, ldaps://{{ ldap_master2 }}:636, ldap://{{ ldap_master1 }}:389, ldap://{{ ldap_master2 }}:389"

# NSLCD 用空格分隔，仅 ldaps://（ssl on 模式不支持混合 URI）
nslcd_uri: "ldaps://{{ ldap_master1 }}:636 ldaps://{{ ldap_master2 }}:636"

#------------------------------------------------------------------------------
# 部署模式：auto（自动检测已有客户端）| sssd | nslcd
# 可在 inventory 中对单台覆盖：ldap_client_mode=sssd
#------------------------------------------------------------------------------
ldap_client_mode: auto

#------------------------------------------------------------------------------
# sudo
#------------------------------------------------------------------------------
ldap_sudo_base: "ou=sudoers,{{ ldap_suffix }}"

#------------------------------------------------------------------------------
# SSSD
#------------------------------------------------------------------------------
sssd_home_base: /share/home

#------------------------------------------------------------------------------
# 附加用户组（如组不存在会自动忽略）
#------------------------------------------------------------------------------
ldap_extra_groups:
  dialout:
    - ic_emu
    - ic_sudoer
  rdma:
    - ic_emu
    - ic_sudoer

#------------------------------------------------------------------------------
# 超时
#------------------------------------------------------------------------------
ldap_timelimit: 120
ldap_timeout: 30
ldap_network_timeout: 5
